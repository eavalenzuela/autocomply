# Copy to deploy/.env.prod (gitignored) and fill in real secrets.
NODE_ENV=production
PORT=3001

# Postgres (the db service reads these; keep the password URL-safe / alphanumeric).
POSTGRES_USER=autocomply
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=autocomply

# API → DB (same password as above; db is the compose service name, internal :5432).
DATABASE_URL=postgresql://autocomply:CHANGE_ME@db:5432/autocomply

# Public origin — drives OAuth redirects, CORS, and secure-cookie behavior.
OAUTH_BASE_URL=https://compliance.eevn.io

# Single admin seeded by `db:seed` (SEED_DEMO_USERS is left unset → no demo users).
ADMIN_EMAIL=admin@compliance.eevn.io
ADMIN_PASSWORD=CHANGE_ME

# Optional: continuous drift-monitoring tick (5 min).
MONITOR_INTERVAL_MS=300000
