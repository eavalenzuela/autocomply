DATABASE_URL=postgresql://autocomply:autocomply@localhost:5433/autocomply
PORT=3001

# Continuous-monitoring scheduler (optional): run the drift tick every N ms.
# MONITOR_INTERVAL_MS=300000

# SSO (optional). Register an OAuth app in your own GitHub/Google account, then
# paste the secrets here (this file's real counterpart, server/.env, is gitignored).
# The SSO buttons appear only when a provider's id+secret are both set.
# OAUTH_BASE_URL=http://localhost:5173
# SSO_DEFAULT_ROLE=viewer

# GitHub: Settings → Developer settings → OAuth Apps → New OAuth App
#   Homepage URL:           http://localhost:5173
#   Authorization callback: http://localhost:5173/api/auth/github/callback
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Google: Cloud Console → APIs & Services → Credentials → OAuth client ID (Web app)
#   Authorized redirect URI: http://localhost:5173/api/auth/google/callback
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
